{
  "name": "baymac.lol",
  "version": "0.1.0",
  "private": true,
  "author": {
    "name": "Parichay Barpanda",
    "email": "me@baymac.lol",
    "url": "https://baymac.lol"
  },
  "scripts": {
    "dev": "NODE_OPTIONS='--inspect' next dev",
    "build": "node scripts/validateWallets.js && node scripts/generateSitemap.js && node scripts/generateRss.js && next build",
    "start": "next start",
    "lint": "biome check .",
    "lint:fix": "biome check --write --unsafe .",
    "format": "biome format --write .",
    "update-content": "./scripts/update_content.sh",
    "test": "yarn test:unit && yarn test:e2e",
    "test:unit": "vitest run",
    "test:unit:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "size": "size-limit"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.2.1",
    "@iconscout/react-unicons": "^2.2.5",
    "classnames": "^2.5.1",
    "date-fns": "^4.1.0",
    "focus-trap-react": "^12.0.0",
    "gray-matter": "^4.0.3",
    "next": "^16.2.4",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "react-hook-form": "^7.62.0",
    "rehype-highlight": "^7.0.2",
    "rehype-stringify": "^10.0.1",
    "remark": "^15.0.1",
    "remark-gfm": "^4.0.1",
    "remark-html": "^16.0.1",
    "remark-rehype": "^11.1.2",
    "use-clipboard-copy": "^0.2.0"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.3",
    "@biomejs/biome": "^2.4.13",
    "@playwright/test": "^1.60.0",
    "@size-limit/preset-app": "^12.1.0",
    "@types/node": "^25.6.0",
    "@types/react": "^19.1.10",
    "@types/react-dom": "^19.1.7",
    "@vitest/coverage-v8": "^4.1.7",
    "globby": "^16.2.0",
    "happy-dom": "^20.9.0",
    "rss": "^1.2.2",
    "size-limit": "^12.1.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.7"
  }
}
